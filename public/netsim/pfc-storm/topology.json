      { "id": "l_core1_agg2", "src": "core1", "dst": "agg2", "capacity_gbps": 400, "packet_scenario": "pfc-ecn-dcqcn-congestion-control" },
      { "id": "l_core2_agg1", "src": "core2", "dst": "agg1", "capacity_gbps": 400, "packet_scenario": "pfc-ecn-dcqcn-congestion-control" },
      { "id": "l_core2_agg2", "src": "core2", "dst": "agg2", "capacity_gbps": 400, "packet_scenario": "pfc-ecn-dcqcn-congestion-control" },

      { "id": "l_agg1_edge1", "src": "agg1", "dst": "edge1", "capacity_gbps": 200, "packet_scenario": "pfc-ecn-dcqcn-congestion-control" },
