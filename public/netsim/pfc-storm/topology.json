{
  "id": "pfc-storm",
  "title": "PFC Storm: Head-of-Line Blocking Propagation",
  "description": "Three-tier RoCEv2 fabric (core / aggregation / edge). One slow receiver causes PFC pauses that propagate up the fabric, starving innocent flows across the entire priority class. Toggle PFC on/off to see congestion collapse instead.",
  "protocol_family": "Fabric Scenarios",
  "difficulty": "advanced",
  "duration_ms": 15000,
  "primary_specs": [
    {
      "document": "IEEE 802.1Qbb",
      "section": "3.2",
      "title": "Priority-based Flow Control"
    },
    {
      "document": "IETF RFC 8926",
      "section": "RoCEv2 Considerations",
      "title": "Remote Direct Memory Access Protocol over UDP/IP"
    }
  ],
  "authors": ["Erik Smith", "Claude"],
  "topology": {
    "width": 900,
    "height": 560,
    "nodes": [
      { "id": "core1", "type": "switch", "label": "Core-1", "x": 320, "y": 80 },
      { "id": "core2", "type": "switch", "label": "Core-2", "x": 580, "y": 80 },

      { "id": "agg1", "type": "switch", "label": "Agg-1", "x": 180, "y": 220 },
      { "id": "agg2", "type": "switch", "label": "Agg-2", "x": 720, "y": 220 },

      { "id": "edge1", "type": "switch", "label": "Edge-1", "x": 100, "y": 360 },
      { "id": "edge2", "type": "switch", "label": "Edge-2", "x": 260, "y": 360 },
      { "id": "edge3", "type": "switch", "label": "Edge-3", "x": 640, "y": 360 },
      { "id": "edge4", "type": "switch", "label": "Edge-4", "x": 800, "y": 360 },

      { "id": "s1", "type": "initiator", "label": "S1", "x": 60, "y": 490 },
      { "id": "s2", "type": "initiator", "label": "S2", "x": 140, "y": 490 },
      { "id": "s3", "type": "initiator", "label": "S3", "x": 220, "y": 490 },
      { "id": "s4", "type": "initiator", "label": "S4", "x": 300, "y": 490 },
      { "id": "s5", "type": "initiator", "label": "S5", "x": 600, "y": 490 },
      { "id": "s6", "type": "initiator", "label": "S6", "x": 680, "y": 490 },
      { "id": "s7", "type": "initiator", "label": "S7", "x": 760, "y": 490 },
      { "id": "slow", "type": "target", "label": "Slow-RX", "x": 840, "y": 490 }
    ],
    "links": [
