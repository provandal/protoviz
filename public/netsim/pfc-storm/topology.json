    ]
  },
  "whatif_params": [
    {
      "id": "pfc_enabled",
      "label": "PFC",
      "type": "enum",
      "options": ["enabled", "disabled"],
      "default": "enabled"
    }
  ],
  "variants": [
    {
      "params": { "pfc_enabled": "enabled" },
      "frames_file": "frames_pfc_enabled.json",
      "description": "PFC enabled (baseline): pause frames prevent loss but propagate back through the fabric, starving innocent flows."
    },
    {
      "params": { "pfc_enabled": "disabled" },
      "frames_file": "frames_pfc_disabled.json",
      "description": "PFC disabled: no pauses, but the slow receiver causes tail drops, triggering RDMA NAKs and congestion collapse."
    }
  ],
  "narrative_events": [
    { "t_ms": 500, "text": "Baseline traffic: all edge servers pushing RDMA WRITE to their local storage targets." },
    { "t_ms": 3000, "text": "Slow receiver begins stalling. Queue at Edge-4 → Slow-RX port begins filling." },
    { "t_ms": 4500, "text": "PFC XOFF sent from Edge-4 to Agg-2. Innocent traffic on Agg-2 → Edge-4 paused." },
    { "t_ms": 6000, "text": "Pause propagates up: Agg-2 → Core-1 and Core-2. Core uplinks now paused." },
    { "t_ms": 8000, "text": "Flows from Edge-1 and Edge-2 destined for Edge-3 (innocent!) are now starved." },
    { "t_ms": 12000, "text": "Slow receiver cleared. Credits return. Watch recovery ripple back down the fabric." }
  ]
}
